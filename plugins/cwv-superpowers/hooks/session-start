#!/usr/bin/env bash
# SessionStart hook for cwv-superpowers plugin.
#
# Inlines the cwv-superpower orchestrator SKILL.md into the session as
# additionalContext, so the agent has the full Step 0–5 flow without
# needing to Read it (which would surface a permission prompt). Peer
# skills (diagnosing-lcp/inp/cls, tracing-with-chrome, setting-up-coredash)
# remain accessed via the Skill tool, which the harness loads internally.
#
# Output format is selected per harness (Claude Code / Cursor / Copilot CLI).

set -euo pipefail

# Resolve plugin root. Harnesses set CLAUDE_PLUGIN_ROOT or CURSOR_PLUGIN_ROOT;
# fall back to the script's own location (script lives at <root>/hooks/session-start).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-$(dirname "$SCRIPT_DIR")}}"

SKILL_FILE="${PLUGIN_ROOT}/skills/cwv-superpower/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  # Skill file missing — emit empty context rather than failing the session.
  printf '{}\n'
  exit 0
fi

skill_body="$(cat "$SKILL_FILE")"

banner_open='<EXTREMELY_IMPORTANT>
You have CWV superpowers.

Below is the full content of your '"'"'cwv-superpowers:cwv-superpower'"'"' orchestrator skill. For the peer skills (diagnosing-lcp, diagnosing-inp, diagnosing-cls, tracing-with-chrome, setting-up-coredash), use the '"'"'Skill'"'"' tool.

---
'
banner_close='
---
</EXTREMELY_IMPORTANT>'

content="${banner_open}${skill_body}${banner_close}"

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context=$(escape_for_json "$content")

# Emit the right output shape per harness.
# Claude Code:  hookSpecificOutput.additionalContext
# Cursor:       additional_context (snake_case)
# Copilot CLI:  additionalContext  (top-level, SDK standard)
#
# Claude Code reads both additional_context and hookSpecificOutput without
# dedup, so we emit only one field per harness.
#
# Uses printf instead of heredoc to avoid bash 5.3+ heredoc hang.
# See: https://github.com/obra/superpowers/issues/571
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$context"
fi

exit 0
